# Configuración del Proyecto Consultechnic
# Página Web Profesional

[PROJECT]
name = Consultechnic Website
version = 1.0.0
description = Página web profesional de Consultechnic
author = Consultechnic Team
created = 2025-01-17

[STRUCTURE]
root = index.html
assets = assets/
images = assets/images/
css = assets/css/
js = assets/js/

[IMAGES]
# Logos principales
logo_white = consultechnic fondo blanco.png
logo_black = consultechnic fondo negro .png

# Imágenes de robots
robot_front = Robot de frente.png
robot_wave = Robot saludando.png
robot_point = Robot señalando a la derecha.png

# Diagramas y recursos
architecture = Ajustes Arq As is final v2-R2R.drawio.png

[DEVELOPMENT]
server_port = 8000
auto_reload = true
debug_mode = false

[DEPLOYMENT]
hosting = Colombia Hosting
ftp_folder = public_html
backup_enabled = true
