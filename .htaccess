# Optimizaciones para Consultechnic
# Archivo .htaccess para mejorar el rendimiento y SEO

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml+rss
</IfModule>

# Cache del navegador
<IfModule mod_expires.c>
    ExpiresActive on
    
    # Imágenes
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS y JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # HTML
    ExpiresByType text/html "access plus 1 day"
    
    # Fuentes
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
    # Protección XSS
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevenir MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Frame Options
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Content Security Policy básica
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://www.google-analytics.com;"
</IfModule>

# Redirección HTTP a HTTPS (descomenta si tienes SSL)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirección www a no-www (personaliza según tu dominio)
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Prevenir acceso a archivos sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|conf)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Proteger archivos de configuración
<Files ~ "^.*\.(env|config|ini|log|sql)$">
    Order allow,deny
    Deny from all
</Files>

# Optimización de rendimiento
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType application/font-woff .woff
    AddType application/font-woff2 .woff2
</IfModule>

# Compresión de archivos específicos
<FilesMatch "\.(css|js|html|xml|txt)$">
    <IfModule mod_deflate.c>
        SetOutputFilter DEFLATE
    </IfModule>
</FilesMatch>

# Cache para archivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# Headers de cache para archivos estáticos
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# Prevenir hotlinking de imágenes (opcional)
# RewriteEngine On
# RewriteCond %{HTTP_REFERER} !^$
# RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?consultechnic.com [NC]
# RewriteRule \.(jpg|jpeg|png|gif)$ - [F]

# Comprimir archivos de texto
<IfModule mod_deflate.c>
    <FilesMatch "\.(html|css|js|xml|txt|svg)$">
        SetOutputFilter DEFLATE
    </FilesMatch>
</IfModule>

# Configuración de caracteres
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .xml .txt

# Configuración de zona horaria (Colombia)
SetEnv TZ America/Bogota

# Optimización para móviles
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirigir dispositivos móviles a versión móvil (opcional)
    # RewriteCond %{HTTP_USER_AGENT} (android|blackberry|iphone|ipad|ipod|iemobile|opera\ mini|mobile|tablet) [NC]
    # RewriteRule ^$ /mobile/ [L,R=302]
</IfModule>

# Configuración de errores personalizados
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# Protección contra ataques comunes
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Bloquear User-Agents maliciosos
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|wget|python|nikto|wkito|pikto|acunetix|havij|libwww-perl|curl|scan|acunetix) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (<|>|'|%0A|%0D|%27|%3C|%3E|%00) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (;|<|>|'|"|\)|\(|%0A|%0D|%22|%27|%3C|%3E|%00).*(libwww-perl|wget|python|nikto|wkito|pikto|acunetix|havij|libwww-perl|curl|scan|acunetix) [NC]
    RewriteRule .* - [F,L]
    
    # Bloquear requests maliciosos
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} proc/self/environ [OR]
    RewriteCond %{QUERY_STRING} mosConfig [OR]
    RewriteCond %{QUERY_STRING} base64_(en|de)code[^(]*\([^)]*\) [OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*iframe.*(\>|%3E) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Configuración de logs (opcional)
# LogLevel warn
# CustomLog /var/log/apache2/consultechnic_access.log combined
# ErrorLog /var/log/apache2/consultechnic_error.log

# Configuración específica para Consultechnic
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Asegurar que index.html se sirva por defecto
    DirectoryIndex index.html index.htm
    
    # Redirigir errores 404 a página principal (opcional)
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule . /index.html [L]
</IfModule>
